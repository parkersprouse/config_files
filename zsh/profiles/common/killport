if [[ -n "$1" ]]; then
  local pids="$(findport -p -q $1)"

  if [[ -z "$pids" ]]; then
    echo "No processes found running on port $1" >&2
    return 1
  fi

  local lines=("${(@f)pids}")
  for pid in $pids; do
    kill $pid
    echo "Successfully killed process with PID $pid running on port $1" >&2
  done
else
  echo 'Usage: killport <port>' >&2
  return 1
fi
