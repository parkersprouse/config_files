if [[ -n "$1" ]]; then
  local pids="$(findport -p -q $1)"

  if [[ -z "$pids" ]]; then
    return_error "No processes found running on port $1"
  fi

  local lines=("${(@f)pids}")
  for pid in $lines; do
    kill $pid
    echo "Successfully killed process with PID $pid running on port $1" >&2
  done
else
  return_error 'Usage: killport <port>'
fi
